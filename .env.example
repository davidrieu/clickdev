# Sanity — créer un projet sur https://www.sanity.io/manage
# Copier ce fichier en .env.local et renseigner les valeurs.

NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-04-18

# Optionnel : token lecture pour preview / données privées (ne jamais exposer côté client)
SANITY_API_READ_TOKEN=

# Lien public Cal.com (bouton « Réserver un créneau » sur la home)
NEXT_PUBLIC_CAL_BOOKING_URL=https://cal.com
